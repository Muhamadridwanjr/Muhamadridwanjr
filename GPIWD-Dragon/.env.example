# ================================================================
# GPIWD-Dragon — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control!
# ================================================================

# --- App ---
APP_NAME=GPIWD-Dragon
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=7777
WORKERS=4

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- PostgreSQL ---
DATABASE_URL=postgresql://gpiwd:gpiwd_pass@localhost:5432/gpiwd

# --- Security ---
SECRET_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_KEY_HEADER=X-GPIWD-Key

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=20

# --- WAF ---
WAF_ENABLED=true
WAF_BLOCK_SQLI=true
WAF_BLOCK_XSS=true
WAF_BLOCK_SSRF=true
WAF_BLOCK_RCE=true
WAF_THREAT_SCORE_THRESHOLD=0.6

# --- IP Intelligence (Optional) ---
# Get your key at: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=
ABUSEIPDB_CONFIDENCE_THRESHOLD=75
# Comma-separated ISO country codes to block (leave empty = allow all)
GEO_BLOCK_COUNTRIES=

# --- AI Security (V4 — leave empty for V1) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_SECURITY_ENABLED=false

# --- Telegram Alerts (Optional but recommended) ---
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false

# --- Dashboard ---
DASHBOARD_ENABLED=true
SOC_POLL_INTERVAL_SECONDS=30

# --- Target Services (upstream apps to protect) ---
TARGET_GAS_BACKEND=http://localhost:8085
TARGET_AI_AGENT=http://localhost:9499
TARGET_AI_STUDIO=http://localhost:9500
